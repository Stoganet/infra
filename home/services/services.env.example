DOMAIN=yourdomain.com
ACME_EMAIL=your@email.com
TZ=Europe/Helsinki

# User/Group IDs for arr stack (run `id $USER` to find out)
PUID=1000
PGID=1000

# Intel Quick Sync GPU groups (run `getent group video/render | cut -d: -f3`)
# Leave empty or comment out Jellyfin devices/group_add if no Intel iGPU
VIDEO_GID=44
RENDER_GID=107

# DNS provider for ACME DNS-01 challenge
# See: https://go-acme.github.io/lego/dns/
DNS_PROVIDER=cloudflare

# DNS provider credentials (use the one matching your provider above)
# CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-token
# HETZNER_API_TOKEN=your-hetzner-token
# NJALLA_TOKEN=your-njalla-token
# PORKBUN_API_KEY=your-porkbun-key
# AWS_ACCESS_KEY_ID=your-aws-key

POSTGRES_PASSWORD=change-me-strong-password
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-strong-password
VPN_PROVIDER=protonvpn
VPN_TYPE=wireguard
VPN_PRIVATE_KEY=your-wireguard-private-key
VPN_SERVER_COUNTRIES=Netherlands
NETBIRD_IP=100.64.x.x

# Arr stack API keys — auto-detected from containers and saved by configure-arr.sh.
# You can also find them manually: docker exec sonarr sed -n 's|.*<ApiKey>\(.*\)</ApiKey>.*|\1|p' /config/config.xml
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=

# qBittorrent WebUI credentials — used by Sonarr/Radarr download client configuration.
# Set the password you chose in the qBittorrent WebUI on first run.
QBIT_USERNAME=admin
QBIT_PASSWORD=