BACKUP_DRIVE_UUID=""
BACKUP_MOUNT="/mnt/backup"
BACKUP_KEYFILE="/etc/backup/backup.key"
DOCKER_VOLUME_PATH="/var/lib/docker/volumes"
COMPOSE_PROJECT="services"

# Space-separated absolute paths to user data directories to back up.
BACKUP_USER_DATA=""

# Space-separated absolute paths to env / config files containing secrets.
BACKUP_ENV_FILES="/srv/stoganet/compose/.env /srv/stoganet/compose/traefik/traefik.yml /srv/stoganet/backup/backup.env /opt/stogad/config.toml"

MIN_DISK_SPACE_GB="10"
VERIFY_BACKUP="true"
NTFY_URL=""
NTFY_TOPIC=""
NTFY_TOKEN=""
ALERT_ON_MISSING="false"
