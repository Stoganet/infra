BACKUP_DRIVE_UUID=""
BACKUP_MOUNT="/mnt/backup"
BACKUP_KEYFILE="/etc/backup/backup.key"
DOCKER_VOLUME_PATH="/var/lib/docker/volumes"
COMPOSE_PROJECT="services"
DB_DUMP_DIR="/var/lib/backups/db_dumps"
BACKUP_USER_DATA="/var/lib/nextcloud/data/USER/files/Photos /var/lib/nextcloud/data/USER/files/Documents"
BACKUP_ENV_FILES="/opt/homeserver/home/services/services.env /opt/homeserver/home/backup/backup.env /opt/homeserver/vps/vps.env /opt/homeserver/vps/authelia/users_database.yml /opt/homed/config.toml"
MIN_DISK_SPACE_GB="10"
VERIFY_BACKUP="true"
NTFY_URL=""
NTFY_TOPIC=""
NTFY_TOKEN=""
ALERT_ON_MISSING="false"
